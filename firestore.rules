rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Public read-only access for the customer-facing shop page (For Sale +
    // Previously Sold sections). Writes still require being signed in below.
    match /forSale/{itemId} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.token.email in ['wong.amaymay@gmail.com', 'floressart92@gmail.com'];
    }
    match /portfolio/{itemId} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.token.email in ['wong.amaymay@gmail.com', 'floressart92@gmail.com'];
    }
    match /{document=**} {
      allow read, write: if request.auth != null
        && request.auth.token.email in ['wong.amaymay@gmail.com', 'floressart92@gmail.com'];
    }
  }
}
